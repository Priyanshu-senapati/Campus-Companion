<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/rvu_primary"
        app:title="@string/tab_more"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <include android:id="@+id/rowTimetable" layout="@layout/include_more_row" />
            <include android:id="@+id/rowAttendance" layout="@layout/include_more_row" />
            <include android:id="@+id/rowLostfound" layout="@layout/include_more_row" />
            <include android:id="@+id/rowCanteen" layout="@layout/include_more_row" />
            <include android:id="@+id/rowChat" layout="@layout/include_more_row" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
