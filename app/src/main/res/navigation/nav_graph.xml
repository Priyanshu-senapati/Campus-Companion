<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment android:id="@+id/splashFragment"
        android:name="com.rvu.campuscompanion.ui.auth.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"
            app:enterAnim="@anim/fade_in" />
        <action android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment" app:popUpToInclusive="true"
            app:enterAnim="@anim/fade_in" />
    </fragment>

    <fragment android:id="@+id/loginFragment"
        android:name="com.rvu.campuscompanion.ui.auth.LoginFragment"
        tools:layout="@layout/fragment_login"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment" app:popUpToInclusive="true"
            app:enterAnim="@anim/fade_in" />
    </fragment>

    <fragment android:id="@+id/registerFragment"
        android:name="com.rvu.campuscompanion.ui.auth.RegisterFragment"
        tools:layout="@layout/fragment_register"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_register_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment" app:popUpToInclusive="true" />
    </fragment>

    <fragment android:id="@+id/dashboardFragment"
        android:name="com.rvu.campuscompanion.ui.home.DashboardFragment"
        tools:layout="@layout/fragment_dashboard"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_dashboard_to_timetable" app:destination="@id/timetableFragment" />
        <action android:id="@+id/action_dashboard_to_attendance" app:destination="@id/attendanceFragment" />
        <action android:id="@+id/action_dashboard_to_lostfound" app:destination="@id/lostFoundFragment" />
        <action android:id="@+id/action_dashboard_to_canteen" app:destination="@id/canteenFragment" />
        <action android:id="@+id/action_dashboard_to_assistant" app:destination="@id/assistantFragment" />
        <action android:id="@+id/action_dashboard_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/dashboardFragment" app:popUpToInclusive="true" />
    </fragment>

    <fragment android:id="@+id/eventsFragment"
        android:name="com.rvu.campuscompanion.ui.events.EventsFragment"
        tools:layout="@layout/fragment_events"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_events_to_detail" app:destination="@id/eventDetailFragment" />
    </fragment>

    <fragment android:id="@+id/eventDetailFragment"
        android:name="com.rvu.campuscompanion.ui.events.EventDetailFragment"
        tools:layout="@layout/fragment_event_detail"
        xmlns:tools="http://schemas.android.com/tools">
        <argument android:name="eventId" app:argType="string" />
    </fragment>

    <fragment android:id="@+id/mapFragment"
        android:name="com.rvu.campuscompanion.ui.map.MapFragment"
        tools:layout="@layout/fragment_map"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment android:id="@+id/profileFragment"
        android:name="com.rvu.campuscompanion.ui.profile.ProfileFragment"
        tools:layout="@layout/fragment_profile"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_profile_to_edit" app:destination="@id/editProfileFragment" />
        <action android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/dashboardFragment" app:popUpToInclusive="true" />
    </fragment>

    <fragment android:id="@+id/editProfileFragment"
        android:name="com.rvu.campuscompanion.ui.profile.EditProfileFragment"
        tools:layout="@layout/fragment_edit_profile"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment android:id="@+id/moreFragment"
        android:name="com.rvu.campuscompanion.ui.home.MoreFragment"
        tools:layout="@layout/fragment_more"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_more_to_timetable" app:destination="@id/timetableFragment" />
        <action android:id="@+id/action_more_to_attendance" app:destination="@id/attendanceFragment" />
        <action android:id="@+id/action_more_to_lostfound" app:destination="@id/lostFoundFragment" />
        <action android:id="@+id/action_more_to_canteen" app:destination="@id/canteenFragment" />
        <action android:id="@+id/action_more_to_chat" app:destination="@id/chatFragment" />
    </fragment>

    <fragment android:id="@+id/timetableFragment"
        android:name="com.rvu.campuscompanion.ui.timetable.TimetableFragment"
        tools:layout="@layout/fragment_timetable"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment android:id="@+id/attendanceFragment"
        android:name="com.rvu.campuscompanion.ui.attendance.AttendanceFragment"
        tools:layout="@layout/fragment_attendance"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_attendance_to_detail" app:destination="@id/attendanceDetailFragment" />
    </fragment>

    <fragment android:id="@+id/attendanceDetailFragment"
        android:name="com.rvu.campuscompanion.ui.attendance.AttendanceDetailFragment"
        tools:layout="@layout/fragment_attendance_detail"
        xmlns:tools="http://schemas.android.com/tools">
        <argument android:name="subject" app:argType="string" />
    </fragment>

    <fragment android:id="@+id/lostFoundFragment"
        android:name="com.rvu.campuscompanion.ui.lostfound.LostFoundFragment"
        tools:layout="@layout/fragment_lostfound"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_lostfound_to_detail" app:destination="@id/itemDetailFragment" />
    </fragment>

    <fragment android:id="@+id/itemDetailFragment"
        android:name="com.rvu.campuscompanion.ui.lostfound.ItemDetailFragment"
        tools:layout="@layout/fragment_item_detail"
        xmlns:tools="http://schemas.android.com/tools">
        <argument android:name="itemId" app:argType="string" />
    </fragment>

    <fragment android:id="@+id/canteenFragment"
        android:name="com.rvu.campuscompanion.ui.canteen.CanteenFragment"
        tools:layout="@layout/fragment_canteen"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_canteen_to_detail" app:destination="@id/menuDetailFragment" />
    </fragment>

    <fragment android:id="@+id/menuDetailFragment"
        android:name="com.rvu.campuscompanion.ui.canteen.MenuDetailFragment"
        tools:layout="@layout/fragment_menu_detail"
        xmlns:tools="http://schemas.android.com/tools">
        <argument android:name="itemId" app:argType="long" />
    </fragment>

    <fragment android:id="@+id/chatFragment"
        android:name="com.rvu.campuscompanion.ui.chat.ChatFragment"
        tools:layout="@layout/fragment_chat"
        xmlns:tools="http://schemas.android.com/tools">
        <action android:id="@+id/action_chat_to_group" app:destination="@id/groupChatFragment" />
    </fragment>

    <fragment android:id="@+id/groupChatFragment"
        android:name="com.rvu.campuscompanion.ui.chat.GroupChatFragment"
        tools:layout="@layout/fragment_group_chat"
        xmlns:tools="http://schemas.android.com/tools">
        <argument android:name="groupId" app:argType="string" />
        <argument android:name="groupName" app:argType="string" />
    </fragment>

    <fragment android:id="@+id/assistantFragment"
        android:name="com.rvu.campuscompanion.ui.assistant.AssistantFragment"
        tools:layout="@layout/fragment_assistant"
        xmlns:tools="http://schemas.android.com/tools" />
</navigation>
